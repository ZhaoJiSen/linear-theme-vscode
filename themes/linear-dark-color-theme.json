  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#62666d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#d0d6e0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "variable.parameter.function-call"
      ],
      "settings": {
        "foreground": "#d98ad9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties / object keys",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "this / self / super",
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants & enum members",
      "scope": [
        "variable.other.constant",
        "constant.other",
        "constant.other.caps",
        "variable.other.enummember",
        "constant.other.enum",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#4cc9d4"
      }
    },
    {
      "name": "Numbers & boolean / null literals",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity",
        "constant.language.nil"
      ],
      "settings": {
        "foreground": "#e08c5a"
      }
    },
    {
      "name": "Escapes & regex",
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp",
        "string.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": {
        "foreground": "#68cc9a"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string",
        "string.template"
      ],
      "settings": {
        "foreground": "#68cc9a"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#828fff"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage (var/let/const/func/class/struct)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#9aa0b3"
      }
    },
    {
      "name": "Functions & methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#e3b341"
      }
    },
    {
      "name": "Function declaration name",
      "scope": [
        "entity.name.function.member",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#e3b341"
      }
    },
    {
      "name": "Classes, types, structs, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.type.interface",
        "entity.name.type.alias",
        "entity.name.type.struct",
        "entity.name.type.enum",
        "meta.type.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "Namespaces / modules / packages",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "entity.name.scope-resolution",
        "entity.name.type.namespace"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "Tags (HTML/JSX/XML/Vue)",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.template",
        "entity.name.tag.script",
        "entity.name.tag.style"
      ],
      "settings": {
        "foreground": "#828fff"
      }
    },
    {
      "name": "Tag angle-bracket punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end",
        "punctuation.definition.tag.html"
      ],
      "settings": {
        "foreground": "#5a6b8c"
      }
    },
    {
      "name": "Component tags (JSX/Vue PascalCase)",
      "scope": [
        "support.class.component",
        "entity.name.tag.namespace",
        "meta.tag.custom"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "Tag attribute names",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#e3b341",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/Vue attribute values",
      "scope": [
        "meta.attribute string.quoted",
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#68cc9a"
      }
    },
    {
      "name": "Vue directives (v-if / @click / :prop / #slot)",
      "scope": [
        "entity.other.attribute-name.vue.directive",
        "meta.directive.vue",
        "entity.other.attribute-name.vue",
        "punctuation.attribute-shorthand.bind.html.vue",
        "punctuation.attribute-shorthand.event.html.vue",
        "punctuation.separator.key-value.html.vue"
      ],
      "settings": {
        "foreground": "#d98ad9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#d98ad9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#8a8f98"
      }
    },
    {
      "name": "Support constants / built-in vars",
      "scope": [
        "support.constant",
        "support.variable",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "Go package & imports",
      "scope": [
        "entity.name.package.go",
        "keyword.package.go",
        "keyword.import.go"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go field tags / runtime",
      "scope": [
        "entity.name.tag.go",
        "support.type.builtin.go"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
