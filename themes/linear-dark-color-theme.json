      ],
      "settings": {
        "foreground": "#e3b341"
      }
    },
    {
      "name": "CSS element / pseudo selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SCSS/LESS variables & mixins",
      "scope": [
        "variable.scss",
        "variable.less",
        "variable.other.less",
        "entity.name.function.scss",
        "keyword.control.at-rule.css"
      ],
      "settings": {
        "foreground": "#d98ad9"
      }
    },
    {
      "name": "CSS at-rules (@media, @import...)",
      "scope": [
        "keyword.control.at-rule",
        "punctuation.definition.keyword.css"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON / YAML keys",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7bb0ff"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#828fff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f7f8f8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d0d6e0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#7bb0ff",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#68cc9a"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#8a8f98",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown list bullet",
      "scope": [
        "markup.list punctuation.definition.list.begin",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#5e6ad2"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#27a644"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#eb5757"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#e3b341"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#eb5757"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#e3b341",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#d98ad9",
    "property": "#7bb0ff",
    "variable.readonly": "#4cc9d4",
    "variable.defaultLibrary": "#828fff",
    "function.defaultLibrary": "#e3b341",
    "class.defaultLibrary": "#7bb0ff",
    "enum": "#7bb0ff",
    "enumMember": "#4cc9d4",
    "type": "#7bb0ff",
    "struct": "#7bb0ff",
    "interface": "#7bb0ff",
    "namespace": "#7bb0ff",
    "decorator": "#d98ad9",
    "macro": "#d98ad9",
    "lifetime": {
      "foreground": "#e08c5a",
      "fontStyle": "italic"
    },
    "selfParameter": {
      "foreground": "#828fff",
      "fontStyle": "italic"
    },
    "keyword": {
      "fontStyle": "italic"
    },
    "comment": {
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  }
}
