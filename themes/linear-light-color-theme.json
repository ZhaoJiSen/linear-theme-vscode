  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#8a8f98",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#3c4149"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "variable.parameter.function-call"
      ],
      "settings": {
        "foreground": "#a838a8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties / object keys",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
      "name": "this / self / super",
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants & enums",
      "scope": [
        "variable.other.constant",
        "constant.other",
        "constant.other.caps",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
      "name": "Numbers & boolean / null literals",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity",
        "constant.language.nil"
      ],
      "settings": {
        "foreground": "#c25a2b"
      }
    },
    {
      "name": "Escapes & regex",
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp",
        "string.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": {
        "foreground": "#1a8a55"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string",
        "string.template"
      ],
      "settings": {
        "foreground": "#1a8a55"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5b51d8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage (var/let/const/func/class/struct)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#6a6f7a"
      }
    },
    {
      "name": "Functions & methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#9a6a00"
      }
    },
    {
      "name": "Function declaration name",
      "scope": [
        "entity.name.function.member",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#9a6a00"
      }
    },
    {
      "name": "Classes, types, structs, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.type.interface",
        "entity.name.type.alias",
        "entity.name.type.struct",
        "entity.name.type.enum",
        "meta.type.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
      "name": "Namespaces / modules / packages",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "entity.name.scope-resolution",
        "entity.name.type.namespace"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
      "name": "Tags (HTML/JSX/XML/Vue)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "entity.name.tag.html",
        "entity.name.tag.template"
      ],
      "settings": {
        "foreground": "#5b51d8"
      }
    },
    {
      "name": "Component tags (JSX/Vue PascalCase)",
      "scope": [
        "support.class.component",
        "entity.name.tag.namespace"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.vue"
      ],
      "settings": {
        "foreground": "#9a6a00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Vue directives",
      "scope": [
        "entity.other.attribute-name.vue.directive",
        "meta.directive.vue"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#a838a8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#62666d"
      }
    },
    {
      "name": "Support constants / built-in vars",
      "scope": [
        "support.constant",
        "support.variable",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#2f6fd0"
      }
    },
    {
