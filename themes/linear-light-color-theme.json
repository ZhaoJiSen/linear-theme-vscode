      "scope": [
        "entity.name.package.go",
        "keyword.package.go",
        "keyword.import.go"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go field tags / runtime",
      "scope": [
        "entity.name.tag.go",
