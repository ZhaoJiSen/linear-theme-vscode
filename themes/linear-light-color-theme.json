        "punctuation.definition.keyword.css"
      ],
      "settings": {
        "foreground": "#5b51d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON / YAML keys",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.toml",
        "entity.name.tag.yaml"
      ],
