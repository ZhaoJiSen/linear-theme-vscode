      ],
      "settings": {
        "foreground": "#9a6a00",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#a838a8",
    "property": "#2f6fd0",
    "variable.readonly": "#2f6fd0",
    "variable.defaultLibrary": "#5b51d8",
    "function.defaultLibrary": "#9a6a00",
    "class.defaultLibrary": "#2f6fd0",
    "enumMember": "#2f6fd0",
    "type": "#2f6fd0",
    "struct": "#2f6fd0",
    "interface": "#2f6fd0",
    "namespace": "#2f6fd0",
    "decorator": "#a838a8",
    "macro": "#a838a8",
    "lifetime": {
      "foreground": "#c25a2b",
      "fontStyle": "italic"
    },
    "selfParameter": {
      "foreground": "#5b51d8",
      "fontStyle": "italic"
    },
    "keyword": {
